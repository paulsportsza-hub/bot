# MzansiEdge Bot — Environment Variables
# Copy this to .env and fill in your values

# Telegram Bot
BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALERT_CHAT_ID=your-alert-group-chat-id
ADMIN_IDS=your-telegram-user-id

# AI
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Odds
ODDS_API_KEY=your-odds-api-key

# Timezone
TZ=Africa/Johannesburg

# Database (async SQLAlchemy)
DATABASE_URL=sqlite+aiosqlite:///mzansiedge.db

# Telegram E2E Testing (optional)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Sentry Error Tracking (optional)
SENTRY_DSN=

# PostHog Analytics (optional)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=

# Stitch Payments (optional)
STITCH_CLIENT_ID=
STITCH_CLIENT_SECRET=
STITCH_WEBHOOK_SECRET=
STITCH_FOUNDING_ID=
STITCH_REDIRECT_URI=https://mzansiedge.co.za/founding-success
STITCH_MOCK_MODE=true
FOUNDING_TERMS_TITLE=MzansiEdge Founding Member Terms
FOUNDING_TERMS_URL=
